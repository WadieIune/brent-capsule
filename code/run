#!/usr/bin/env bash
# Punto de entrada de la cápsula Code Ocean — BRENT Pattern System v2.
# Code Ocean ejecuta /code/run. Lee datos de /data y escribe en /results.
set -euo pipefail

cd "$(dirname "$0")"          # -> /code
mkdir -p /results

# Config seleccionable por variable de entorno (por defecto: CPU reproducible).
# GPU:  CONFIG=/code/config_gpu.yaml /code/run
CONFIG="${CONFIG:-/code/config_codeocean.json}"

echo "=================================================================="
echo " BRENT Pattern System v2 — Reproducible Run (Code Ocean)"
echo " Config: ${CONFIG}"
echo "=================================================================="
python --version
python -c "import torch, numpy, pandas; print('torch', torch.__version__, '| numpy', numpy.__version__, '| pandas', pandas.__version__)"
echo "------------------------------------------------------------------"

# Entrenamiento + validación cruzada purgada (walk-forward) + backtest (DSR/PBO)
# + generación de resultados en Excel y manifiesto de reproducibilidad.
python -m brent_pattern_system.train_torch --config "${CONFIG}"

echo "------------------------------------------------------------------"
echo "Resultados escritos en /results :"
ls -R /results || true
echo "Run completado."
